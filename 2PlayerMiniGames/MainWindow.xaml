<Window x:Class="_2PlayerMiniGames.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="2PlayerMiniGames" Height="350" Width="400"
        WindowStartupLocation="CenterScreen">
	<Grid Background="#20232A">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Text="GameHub - 2 játékos minigame-ek"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="10"
                   HorizontalAlignment="Center"/>

		<Border Grid.Row="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="250"
                Background="#282C34"
                Padding="20"
                CornerRadius="8">
			<StackPanel>
				<TextBlock Text="Válaszd ki a játékot:"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

				<Button Content="TicTacToe (X - O)"
                        Margin="0,5"
                        Padding="8"
                        Click="TicTacToe_Click"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>