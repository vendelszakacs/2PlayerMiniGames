<Window x:Class="_2PlayerMiniGames.TicTacToeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TicTacToe - 2 játékos" Height="350" Width="300"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#20232A" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText"
                   Grid.Row="0"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"
                   Text="Következő: X"/>

        <UniformGrid Grid.Row="1" Rows="3" Columns="3" Margin="0,0,0,10">
            <Button x:Name="Cell00" FontSize="32" Click="Cell_Click" Tag="0,0" Margin="2"/>
            <Button x:Name="Cell01" FontSize="32" Click="Cell_Click" Tag="0,1" Margin="2"/>
            <Button x:Name="Cell02" FontSize="32" Click="Cell_Click" Tag="0,2" Margin="2"/>

            <Button x:Name="Cell10" FontSize="32" Click="Cell_Click" Tag="1,0" Margin="2"/>
            <Button x:Name="Cell11" FontSize="32" Click="Cell_Click" Tag="1,1" Margin="2"/>
            <Button x:Name="Cell12" FontSize="32" Click="Cell_Click" Tag="1,2" Margin="2"/>

            <Button x:Name="Cell20" FontSize="32" Click="Cell_Click" Tag="2,0" Margin="2"/>
            <Button x:Name="Cell21" FontSize="32" Click="Cell_Click" Tag="2,1" Margin="2"/>
            <Button x:Name="Cell22" FontSize="32" Click="Cell_Click" Tag="2,2" Margin="2"/>
        </UniformGrid>

        <Button Grid.Row="2"
                Content="Új játék"
                Height="30"
                Click="NewGame_Click"/>
    </Grid>
</Window>

