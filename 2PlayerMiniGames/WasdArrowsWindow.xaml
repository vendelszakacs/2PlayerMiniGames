<Window x:Class="_2PlayerMiniGames.WasdArrowsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WASD vs Nyilak - 2 játékos" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Grid Background="#20232A" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText"
                   Grid.Row="0"
                   Foreground="White"
                   FontSize="14"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"
                   Text="Piros: WASD, Kék: nyilak. Cél: érj a másik oldalra!"/>

        <Canvas x:Name="GameCanvas"
                Grid.Row="1"
                Background="#282C34"
                Margin="0,0,0,10">
            <Rectangle x:Name="RedPlayer"
                       Width="30" Height="30"
                       Fill="Red"/>
            <Rectangle x:Name="BluePlayer"
                       Width="30" Height="30"
                       Fill="DeepSkyBlue"/>
        </Canvas>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
            <Button Content="Új játék" Margin="5" Click="NewGame_Click"/>
            <TextBlock x:Name="ScoreText"
                       Foreground="White"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>

